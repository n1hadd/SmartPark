@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Izbriši osebne podatke";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<h3>@ViewData["Title"]</h3>

<div class="alert alert-warning" role="alert">
    <p>
        <strong>Brisanje teh podatkov bo trajno odstranilo vaš račun in tega ni mogoče povrniti.</strong>
    </p>
</div>

<div>
    <form id="delete-user" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        @if (Model.RequirePassword)
        {
            <div class="form-floating mb-3">
                <input asp-for="Input.Password"
                       class="form-control"
                       autocomplete="current-password"
                       aria-required="true"
                       placeholder="Vnesite svoje geslo." />
                <label asp-for="Input.Password" class="form-label"></label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
        }

        <button class="w-100 btn btn-lg btn-danger" type="submit">
            Izbriši podatke in zapri moj račun
        </button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}