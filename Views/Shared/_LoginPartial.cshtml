@using Microsoft.AspNetCore.Identity
@inject SignInManager<SmartPark.Models.ApplicationUser> SignInManager
@inject UserManager<SmartPark.Models.ApplicationUser> UserManager

@{
    var path = (Context.Request.Path.Value ?? "").ToLowerInvariant();
    var isManage = path.StartsWith("/identity/account/manage");
}

<style>
    .sp-auth {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 10px;
        align-items: stretch;
    }

    .sp-pill {
        display: block;
        width: 100%;
        text-align: center;
        padding: 10px 12px;
        border-radius: 14px;
        font-weight: 850;
        text-decoration: none;
        background: rgba(255,255,255,.12);
        color: rgba(255,255,255,.95);
    }

    .sp-pill:hover { background: rgba(255,255,255,.18); color: #fff; }

    .sp-logout-btn {
        width: 100%;
        border: 0;
        border-radius: 14px;
        padding: 10px 12px;
        font-weight: 900;
        background: #ff4d6d;
        color: #fff;
    }
</style>

<ul class="sp-auth">
@if (SignInManager.IsSignedIn(User))
{
    <li>
        <a class="sp-pill" href="/Identity/Account/Manage">
            @User.Identity?.Name
        </a>
    </li>

    
    @if (isManage)
    {
        <li>
            <form id="logoutForm" action="/Identity/Account/Logout?returnUrl=%2F" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="sp-logout-btn">Odjava</button>
            </form>
        </li>
    }
}
else
{
    <li>
        <a class="sp-pill" href="/Identity/Account/Login">Prijava</a>
    </li>
    <li>
        <a class="sp-pill" href="/Identity/Account/Register">Registracija</a>
    </li>
}
</ul>