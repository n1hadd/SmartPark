@model IEnumerable<SmartPark.Models.Parkirisce>

@{
    ViewData["Title"] = "Domov";
}

<div class="sp-card sp-map-wrap">
    <div class="d-flex gap-2 mb-3 align-items-end flex-wrap">
        <div style="min-width:280px; flex:1;">
            <label class="form-label mb-1" style="margin-left: 7px; font-weight: bold;">Išči lokacijo</label>
            <input id="spLocalSearch" class="form-control" placeholder="npr. Kongresni trg" />
        </div>

        <div style="width:180px;">
            <label class="form-label mb-1" style="margin-left: 7px; font-weight: bold;">Max €/h</label>
            <input id="spMaxPrice" type="number" step="0.1" min="0" class="form-control" placeholder="npr. 3.0" />
        </div>

        <div>
            <button type="button" class="btn btn-outline-secondary" id="spClearFilters">Počisti</button>
        </div>
    </div>

   <div id="map" style="height: 600px; width:100%; border-radius:16px; overflow:hidden;"></div>
</div>
<!-- Modal za rezervacijo -->
<div class="modal fade" id="rezervacijaModal" tabindex="-1" aria-labelledby="rezervacijaModalLabel" aria-hidden="true">
   <div class="modal-dialog">
      <div class="modal-content">
         <form id="rezervacijaForm">
            @Html.AntiForgeryToken()
            <div class="modal-header">
               <h5 class="modal-title" id="rezervacijaModalLabel">Rezervacija parkirišča</h5>
               <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zapri"></button>
            </div>
            <div class="modal-body">
               <input type="hidden" id="parkId" name="ParkirisceId" />
               <input type="hidden" id="parkPrice" />
               <input type="hidden" id="parkirnoMestoId" name="ParkirnoMestoId" />
               <div class="mb-3">
                  <label class="form-label">Parkirišče</label>
                  <input type="text" id="parkNaslov" class="form-control" readonly />
               </div>
               <div class="mb-3">
                  <label class="form-label">Začetek</label>
                  <input type="datetime-local" id="startTime" name="DatumZacetka" class="form-control" required />
               </div>
               <div class="mb-3">
                  <label class="form-label">Konec</label>
                  <input type="datetime-local" id="endTime" name="DatumKonca" class="form-control" required />
               </div>
               <div class="mb-3">
                  <label class="form-label">Cena na uro</label>
                  <input type="text" id="parkCena" class="form-control" readonly />
               </div>
               <div class="mb-3">
                  <label class="form-label">Skupna cena</label>
                  <input type="text" id="totalPrice" class="form-control" readonly value="0.00 €" />
               </div>
               <div class="alert alert-info py-2 mb-0" id="availabilityInfo">
                  Izberi začetek in konec za preverjanje prostih mest.
               </div>
            </div>
            <div class="modal-footer">
               <!-- NOVO: cancel gumb -->
               <button type="button" class="btn btn-outline-secondary" id="cancelRezervacijaBtn">Prekliči</button>
               <!-- submit gumb: bo disable dokler ni prostega mesta -->
               <button type="submit" class="btn btn-primary" id="submitRezervacijaBtn" disabled>Rezerviraj</button>
            </div>
         </form>
      </div>
   </div>
</div>
<!-- Modal za plačilo -->
<div class="modal fade" id="placiloModal" tabindex="-1" aria-hidden="true">
   <div class="modal-dialog">
      <div class="modal-content">
         <div class="modal-header">
            <h5 class="modal-title">Plačilo rezervacije</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Zapri"></button>
         </div>
         <div class="modal-body">
            <input type="hidden" id="rezervacijaIdHidden" />
            <div class="mb-3">
               <label class="form-label">Način plačila</label>
               <select id="paymentMethod" class="form-select">
                  <option value="card">Bančna kartica</option>
                  <option value="nalog">Plačilni nalog</option>
               </select>
            </div>
            
            <div id="cardFields" style="display:none;">
               <div class="mb-2">
                  <label class="form-label">Ime na kartici</label>
                  <input id="cardName" class="form-control" autocomplete="cc-name" />
               </div>
               <div class="mb-2">
                  <label class="form-label">Številka kartice</label>
                  <input id="cardNumber" class="form-control" inputmode="numeric" autocomplete="cc-number" placeholder="1234 5678 9012 3456" />
               </div>
               <div class="row">
                  <div class="col-6 mb-2">
                     <label class="form-label">Veljavnost (MM/YY)</label>
                     <input id="cardExp" class="form-control" inputmode="numeric" autocomplete="cc-exp" placeholder="MM/YY" />
                  </div>
                  <div class="col-6 mb-2">
                     <label class="form-label">CVV</label>
                     <input id="cardCvv" class="form-control" inputmode="numeric" autocomplete="cc-csc" placeholder="123" />
                  </div>
               </div>
               <div class="small text-muted">
                  Opomba: To je demo validacija (ne izvaja prave transakcije).
               </div>
            </div>
         </div>
         <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Prekliči</button>
            <button type="button" class="btn btn-success" onclick="simulatePayment()">Plačaj</button>
         </div>
      </div>
   </div>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    var map = L.map('map').setView([46.0511, 14.5051], 17);

    L.tileLayer('https://tiles.stadiamaps.com/tiles/alidade_smooth/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; Stadia Maps &copy; OSM',
        maxZoom: 20
    }).addTo(map);

    var parkirisca = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model,
        new System.Text.Json.JsonSerializerOptions {
            ReferenceHandler = System.Text.Json.Serialization.ReferenceHandler.IgnoreCycles
        }
    ));

    function setAvailability(message, type) {
        const el = document.getElementById('availabilityInfo');
        const btn = document.getElementById('submitRezervacijaBtn');

        el.classList.remove('alert-info', 'alert-success', 'alert-danger');
        el.classList.add(type === 'ok' ? 'alert-success' : type === 'bad' ? 'alert-danger' : 'alert-info');
        el.textContent = message;

        // enable submit samo, če imamo veljavno mestoId
        const mestoId = document.getElementById('parkirnoMestoId').value;
        btn.disabled = (!mestoId || mestoId === "0");
    }

    async function fetchProstoMesto() {
        var parkId = document.getElementById('parkId').value;
        var start = document.getElementById('startTime').value;
        var end = document.getElementById('endTime').value;

        // reset pri nepopolnih podatkih
        document.getElementById('parkirnoMestoId').value = "0";
        document.getElementById('submitRezervacijaBtn').disabled = true;

        if (!parkId || !start || !end) {
            setAvailability("Izberi začetek in konec za preverjanje prostih mest.", "info");
            return;
        }

        // validacija na frontendu
        var diffMs = new Date(end) - new Date(start);
        if (diffMs <= 0) {
            setAvailability("Neveljaven interval (konec mora biti po začetku).", "bad");
            return;
        }

        const url = `/Rezervacije/GetProstoMesto?parkirisceId=${encodeURIComponent(parkId)}&zacetek=${encodeURIComponent(start)}&konec=${encodeURIComponent(end)}`;

        try {
            const res = await fetch(url);
            const mestoId = await res.json();

            document.getElementById('parkirnoMestoId').value = (mestoId ?? 0).toString();

            if (!mestoId || mestoId === 0) {
                setAvailability("Ni prostih mest za izbrani termin. Poskusi drug termin.", "bad");
            } else {
                setAvailability("Prosto mesto je na voljo.", "ok");
            }
        } catch (e) {
            console.error(e);
            setAvailability("Napaka pri preverjanju prostih mest.", "bad");
        }
    }

    function showRezervacijaModal() {
        var modal = new bootstrap.Modal(document.getElementById('rezervacijaModal'));
        modal.show();
    }

    var spMarkers = [];

    parkirisca.forEach(function (p) {
        if (p.Latitude && p.Longitude) {
            var marker = L.marker([p.Latitude, p.Longitude]).addTo(map);

            marker.bindPopup(
            "<b>" + p.Naslov + "</b><br>" +
            "Cena na uro: " + p.CenaNaUro + " €<br>" +
            "Delovni čas: " + p.DelovniCas + "<br>" +
            "Prosta mesta: " + (p.ParkirnaMesta ? p.ParkirnaMesta.filter(m => !m.Zasedeno).length : 'N/A') +
            "<br><button class='btn btn-sm btn-primary mt-2' onclick='openRezervacija(" + p.Id + ")'>Rezerviraj</button>"
            );

            spMarkers.push({
            id: p.Id,
            title: (p.Naslov || ""),
            price: Number(p.CenaNaUro || 0),
            marker: marker
            });
        }
    });

    function applyFilters() {
        const q = (document.getElementById("spLocalSearch")?.value || "").toLowerCase().trim();
        const maxPriceRaw = (document.getElementById("spMaxPrice")?.value || "").trim();
        const maxPrice = maxPriceRaw ? Number(maxPriceRaw) : null;

        spMarkers.forEach(x => {
            const matchText = !q || (x.title || "").toLowerCase().includes(q);
            const matchPrice = (maxPrice == null) || (x.price <= maxPrice);

            const visible = matchText && matchPrice;
            if (visible) x.marker.addTo(map);
            else map.removeLayer(x.marker);
        });
    }

    document.addEventListener('DOMContentLoaded', function () {
        const s = document.getElementById("spLocalSearch");
        const p = document.getElementById("spMaxPrice");
        const c = document.getElementById("spClearFilters");

        if (s) s.addEventListener("input", applyFilters);
        if (p) p.addEventListener("input", applyFilters);

        if (c) {
            c.addEventListener("click", function () {
            if (s) s.value = "";
            if (p) p.value = "";
            applyFilters();
            });
        }
    });

    function resetRezervacijaForm() {
        document.getElementById('parkId').value = "";
        document.getElementById('parkNaslov').value = "";
        document.getElementById('parkPrice').value = "";
        document.getElementById('parkCena').value = "";
        document.getElementById('startTime').value = "";
        document.getElementById('endTime').value = "";
        document.getElementById('totalPrice').value = "0.00 €";
        document.getElementById('parkirnoMestoId').value = "0";
        document.getElementById('submitRezervacijaBtn').disabled = true;
        setAvailability("Izberi začetek in konec za preverjanje prostih mest.", "info");
    }

    function fillAndShowModal(p) {
        document.getElementById('parkId').value = p.Id;
        document.getElementById('parkNaslov').value = p.Naslov;
        document.getElementById('parkPrice').value = p.CenaNaUro;
        document.getElementById('parkCena').value = p.CenaNaUro + " €";

        document.getElementById('startTime').value = "";
        document.getElementById('endTime').value = "";
        document.getElementById('totalPrice').value = "0.00 €";
        document.getElementById('parkirnoMestoId').value = "0";

        document.getElementById('startTime').onchange = updateTotal;
        document.getElementById('endTime').onchange = updateTotal;

        document.getElementById('submitRezervacijaBtn').disabled = true;
        setAvailability("Izberi začetek in konec za preverjanje prostih mest.", "info");

        showRezervacijaModal();
    }

    function openRezervacija(id) {
        var p = parkirisca.find(x => x.Id === id);
        if (p) fillAndShowModal(p);
    }

    function updateTotal() {
        var start = document.getElementById('startTime').value;
        var end = document.getElementById('endTime').value;
        var pricePerHour = parseFloat(document.getElementById('parkPrice').value) || 0;

        if (!start || !end) {
            document.getElementById('totalPrice').value = "0.00 €";
            fetchProstoMesto();
            return;
        }

        var diffMs = new Date(end) - new Date(start);
        if (diffMs <= 0) {
            document.getElementById('totalPrice').value = "0.00 €";
            fetchProstoMesto();
            return;
        }

        var hours = diffMs / (1000 * 60 * 60);
        var total = hours * pricePerHour;

        document.getElementById('totalPrice').value = total.toFixed(2) + " €";
        fetchProstoMesto();
    }

    // Submit rezervacije -> odpre modal za plačilo
    document.addEventListener('DOMContentLoaded', function () {
        var form = document.getElementById('rezervacijaForm');

        function getAntiForgeryToken() {
            const tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
            return tokenInput ? tokenInput.value : "";
        }

        // NOVO: Cancel gumb zapre modal in resetira
        document.getElementById('cancelRezervacijaBtn').addEventListener('click', function () {
            resetRezervacijaForm();
            const modalEl = document.getElementById('rezervacijaModal');
            const instance = bootstrap.Modal.getInstance(modalEl);
            if (instance) instance.hide();
        });

        form.addEventListener('submit', function (e) {
            e.preventDefault();

            // D) blokada submit, če je 0
            const mestoId = document.getElementById('parkirnoMestoId').value;
            if (!mestoId || mestoId === "0") {
                alert("Ni prostih mest za izbrani termin. Izberi drug termin ali drugo parkirišče.");
                return;
            }

            fetch('/Rezervacije/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': getAntiForgeryToken()
                },
                body: new URLSearchParams(new FormData(form))
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('rezervacijaIdHidden').value = data.rezervacijaId;

                    var rezervacijaModal = bootstrap.Modal.getInstance(document.getElementById('rezervacijaModal'));
                    rezervacijaModal.hide();

                    var placiloModal = new bootstrap.Modal(document.getElementById('placiloModal'));
                    placiloModal.show();
                } else {
                    alert(data.message || "Rezervacija ni uspela.");
                }
            })
            .catch(() => alert("Napaka pri komunikaciji s strežnikom."));
        });
    });

    function simulatePayment() {
        const rezervacijaId = document.getElementById("rezervacijaIdHidden").value;
        const method = document.getElementById("paymentMethod").value;

        if (!rezervacijaId) {
            alert("Manjka ID rezervacije. Najprej izvedi rezervacijo.");
            return;
        }

        if (method === "card") {
            const err = validateCardFields();
            if (err) { alert(err); return; }
        }

        fetch('/Placila/Create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rezervacijaId: rezervacijaId, nacinPlacila: method })
        })
        .then(async r => {
            const text = await r.text();
            let data = null;
            try { data = JSON.parse(text); } catch {}

            if (!r.ok) {
            console.error("Placila/Create failed:", r.status, text);
            alert((data && data.message) ? data.message : ("Napaka pri plačilu (HTTP " + r.status + ")."));
            return;
            }

            if (data && data.success) {
            alert("Plačilo uspešno! Znesek: " + data.znesek + " €");
            window.location.href = "/Rezervacije/Index";
            } else {
            alert((data && data.message) ? data.message : "Napaka pri plačilu ❌");
            }
        })
        .catch(() => alert("Napaka pri komunikaciji s strežnikom."));
    }

    function normalizeCardNumber(v) {
        return (v || "").replace(/\s+/g, "");
    }

    function validateCardFields() {
        const name = (document.getElementById("cardName").value || "").trim();
        const number = normalizeCardNumber(document.getElementById("cardNumber").value);
        const exp = (document.getElementById("cardExp").value || "").trim();
        const cvv = (document.getElementById("cardCvv").value || "").trim();

        if (!name) return "Vnesi ime na kartici.";
        if (!/^\d{16}$/.test(number)) return "Številka kartice mora imeti 16 številk.";
        if (!/^\d{2}\/\d{2}$/.test(exp)) return "Veljavnost mora biti v obliki MM/YY.";
        const mm = parseInt(exp.substring(0,2), 10);
        if (isNaN(mm) || mm < 1 || mm > 12) return "Mesec veljavnosti mora biti med 01 in 12.";
        if (!/^\d{3}$/.test(cvv)) return "CVV mora imeti 3 številke.";
        return null;
    }

    document.addEventListener('DOMContentLoaded', function () {
        const paymentMethod = document.getElementById("paymentMethod");
        const cardFields = document.getElementById("cardFields");

        if (paymentMethod && cardFields) {
            const sync = () => {
            cardFields.style.display = (paymentMethod.value === "card") ? "" : "none";
            };
            paymentMethod.addEventListener("change", sync);
            sync();
        }
    });

</script>
}